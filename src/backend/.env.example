# MeoArc Backend — biến môi trường (MẪU).
# Cách dùng: copy file này thành `.env` rồi điền giá trị THẬT.
# LƯU Ý: file `.env` chứa BÍ MẬT → KHÔNG commit lên Git (đã có trong .gitignore).

# Lấy 2 giá trị này từ Google Cloud Console:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Phải KHỚP y hệt "Authorized redirect URI" khai trong Google Cloud:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Frontend (để redirect về sau khi đăng nhập xong):
FRONTEND_URL=http://localhost:5173

# Phiên đăng nhập sống bao lâu (giờ):
SESSION_TTL_HOURS=24

# Database — nhóm dùng PostgreSQL. Định dạng:
#   postgresql+psycopg://NGƯỜI_DÙNG:MẬT_KHẨU@HOST:CỔNG/TÊN_DB
# Ví dụ chạy Postgres ở máy: tạo DB tên "meoarc" rồi điền dòng dưới.
# Nếu để TRỐNG / không có dòng này → tự dùng SQLite file (sqlite:///./meoarc.db).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/meoarc
